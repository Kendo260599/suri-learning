# Environment Variables Template for Vercel Deployment
# Copy this file to .env.local and fill in your values

# =====================
# GEMINI AI API KEY
# =====================
# Server-side API key for Gemini AI (used in API routes)
GEMINI_API_KEY=your_gemini_api_key_here

# =====================
# FIREBASE CONFIGURATION (from Firebase Console → Project Settings → Web App)
# =====================
# Client-side Firebase config (these are public, safe to expose)
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyDE4dPaA3nj5bncolxC9yFkftPNThbvSNg
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=suri-learning.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=suri-learning
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=suri-learning.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=880701007277
NEXT_PUBLIC_FIREBASE_APP_ID=1:880701007277:web:ec740a32869a96d0a56d24
# Firestore database ID (usually default, or your custom database ID)
# NEXT_PUBLIC_FIREBASE_DATABASE_ID=(default)

# =====================
# FIREBASE ADMIN (Optional - for server-side operations)
# =====================
# FIREBASE_ADMIN_PROJECT_ID=suri-learning
# FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
# FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
