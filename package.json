{
  "name": "suri-learning",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/ielts",
    "dev:ielts": "npm run dev --workspace=apps/ielts",
    "dev:hsk": "npm run dev --workspace=apps/hsk",
    "build": "npm run build --workspace=apps/ielts",
    "build:ielts": "npm run build --workspace=apps/ielts",
    "build:hsk": "npm run build --workspace=apps/hsk",
    "start": "npm run start --workspace=apps/ielts",
    "preview:hsk": "npm run preview --workspace=apps/hsk",
    "test": "npm run test --workspace=apps/ielts",
    "test:hsk": "npm run test --workspace=apps/hsk",
    "test:ielts": "npm run test --workspace=apps/ielts",
    "test:e2e": "npm run test:e2e --workspace=apps/ielts",
    "lint": "npm run lint --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present",
    "install:ielts": "npm install --workspace=apps/ielts",
    "install:hsk": "npm install --workspace=apps/hsk"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
